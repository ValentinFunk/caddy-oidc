{
    auto_https off
    log {
        level DEBUG
    }

    oidc example {
        issuer http://oidc-provider/example
        client_id xyz
        secret_key {env.OIDC_SECRET_KEY}
        scope openid email
        claim email
        username email
        cookie {
            insecure
        }
    }
}

http:// {
    log

    oidc example {
        allow {
            user admin@example.com
        }
    }

    header X-User-Claim-Email "{http.auth.user.claim.email}" {
        defer
    }
    respond "{http.auth.user.id}"
}